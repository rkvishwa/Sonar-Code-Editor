# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://your-appwrite-endpoint/v1
VITE_APPWRITE_PROJECT_ID=project_id

# Database Configuration
VITE_APPWRITE_DB_NAME=db_name
VITE_APPWRITE_COLLECTION_TEAMS=teams
VITE_APPWRITE_COLLECTION_SESSIONS=sessions
VITE_APPWRITE_COLLECTION_ACTIVITY_LOGS=activityLogs
VITE_APPWRITE_COLLECTION_REPORTS=reports
VITE_APPWRITE_COLLECTION_SETTINGS=settings

BUILD_SIGNING_KEY=

# Build Integrity Signing
# Required by scripts/generate-seal.js and scripts/verify-keys.js
# Use a single-line PEM string with literal \n characters in CI/local env files.
SEAL_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
SEAL_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
