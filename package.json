{
  "name": "sonar-ide",
  "version": "1.0.0-beta.6",
  "description": "Sonar Code Editor & Monitoring System",
  "main": "dist/main/main.js",
  "author": "Knurdz",
  "license": "MIT",
  "scripts": {
    "serve": "npm run build && npm run start",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:preload\" \"npm run dev:main\"",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:main": "node scripts/build-main.js --watch",
    "dev:preload": "esbuild src/preload/preload.ts --bundle --platform=node --external:electron --outfile=dist/preload/preload.js --watch",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "start": "concurrently \"npm run dev:renderer\" \"npm run dev:preload\" \"npm run dev:main\" \"npm run dev:electron\"",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload && electron scripts/build-bytecode.js && node scripts/generate-attestation.js",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "node scripts/build-main.js",
    "build:preload": "esbuild src/preload/preload.ts --bundle --platform=node --external:electron --outfile=dist/preload/preload.js",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false && npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "appwrite:init": "cp appwrite.config.json appwrite.json && appwrite init project",
    "appwrite:push": "appwrite push all"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/colors": "^3.0.0",
    "@types/ws": "^8.18.1",
    "appwrite": "^16.1.0",
    "bcryptjs": "^3.0.3",
    "bytenode": "^1.5.7",
    "electron-store": "^8.1.0",
    "is-online": "^12.0.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^2.0.19",
    "react-router-dom": "^6.22.0",
    "ws": "^8.19.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^35.7.5",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.4",
    "fs": "^0.0.1-security",
    "fs-extra": "^11.3.4",
    "path": "^0.12.7",
    "svelte-marquee": "^0.1.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.sonar.editor",
    "productName": "Sonar Code Editor",
    "icon": "build/icon.png",
    "afterPack": "scripts/generate-seal.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/renderer",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/renderer",
        "to": "renderer"
      }
    ],
    "protocols": [
      {
        "name": "Sonar Editor Invite",
        "schemes": [
          "sonar-editor"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
